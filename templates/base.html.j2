<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ title }}</title>
<style>
  body {
    font-family: Georgia, "Times New Roman", serif;
    background: #fff;
    color: #000;
    margin: 0 auto;
    padding: 1em 1.2em 2em;
    max-width: 38em;
    font-size: 20px;
    line-height: 1.5;
  }
  h1 { font-size: 1.3em; border-bottom: 2px solid #000; padding-bottom: .3em; margin-bottom: .3em; }
  h2 { font-size: 1.1em; margin-top: 1.6em; border-bottom: 1px solid #000; padding-bottom: .2em; }
  h3 { font-size: 1.05em; margin-bottom: .2em; }
  p { margin: .4em 0; }
  .meta { color: #333; font-size: .85em; margin-bottom: 1em; }
  .summary { margin: 0 0 .3em 0; white-space: pre-line; }
  .source { font-size: .8em; color: #333; }
  a { color: #000; }
  article { margin-bottom: 1.4em; padding-bottom: 1em; border-bottom: 1px dashed #999; }
  ul.toc { padding-left: 1.1em; }
  ul.toc li { margin: .3em 0; }
</style>
</head>
<body>
{% block content %}{% endblock %}
</body>
</html>
